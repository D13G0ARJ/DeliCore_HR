# Vercel env example (Laravel API)
# Set these as Environment Variables in Vercel.

APP_NAME="Delicore HR"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-vercel-api-domain.vercel.app

LOG_CHANNEL=stderr
LOG_LEVEL=info

# Supabase Postgres
DB_CONNECTION=pgsql
DB_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
DB_SSLMODE=require
DB_SEARCH_PATH=public

# Serverless-friendly defaults
CACHE_STORE=array
QUEUE_CONNECTION=sync
SESSION_DRIVER=cookie

# Trust proxy headers behind Vercel
TRUSTED_PROXIES=*
