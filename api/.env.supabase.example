# Supabase Postgres env example
# Copy to .env and fill in values (or set env vars in your host).

APP_NAME="Delicore HR"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-api-domain.example

LOG_CHANNEL=stack
LOG_LEVEL=info

# Database (Supabase)
DB_CONNECTION=pgsql
DB_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
DB_SSLMODE=require
DB_SEARCH_PATH=public

# CORS (frontend domains allowed to call this API)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Recommended for stateless API deployments
CACHE_STORE=array
QUEUE_CONNECTION=sync
SESSION_DRIVER=cookie

# If you use Vite assets in Laravel (not required for this API-only app)
VITE_APP_NAME="${APP_NAME}"
