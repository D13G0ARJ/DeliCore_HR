{
    "version": 2,
    "framework": null,
    "functions": {
        "public/index.php": {
            "runtime": "vercel-php@0.7.5"
        }
    },
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "public/index.php"
        },
        {
            "src": "/(.*)",
            "dest": "public/index.php"
        }
    ]
}